{
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python",
            "config": {
                "maxDuration": 60
            }
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "api/index.py"
        }
    ],
    "env": {
        "PYTHONPATH": "."
    }
}